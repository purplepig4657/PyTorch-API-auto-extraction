%import common.WS
%ignore WS


type: t

t: string
 | union_type
 | generic_type
 | list_type
 | const_t

union_type: t ("|" t)*

generic_type: t "[" t ((",") t)* "]"

list_type: "[]"
         | "[" t ((",") t)* "]"

const_t: "'" t "'"


string: TYPE_LIST -> type_list
      | TYPE_NAME -> type_name


TYPE_LIST: "..."
TYPE_NAME: /[a-zA-Z_][a-zA-Z0-9_.]*/
